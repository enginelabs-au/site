# Copy to .env or .env.local (never commit those files).

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7
OPENROUTER_SITE_URL=https://enginelabs.com.au
OPENROUTER_APP_NAME=Engine Labs

CONTROL_CENTRE_USER_SPEND_CAP_USD=1
CONTROL_CENTRE_MAX_CLARIFY_OUTPUT_TOKENS=384
CONTROL_CENTRE_MAX_RECOMMEND_OUTPUT_TOKENS=1536
CONTROL_CENTRE_MAX_INPUT_CHARS_PER_MESSAGE=600
CONTROL_CENTRE_MAX_USER_TURNS=5
CONTROL_CENTRE_MAX_CONTEXT_MESSAGES=10
CONTROL_CENTRE_MIN_RESERVE_USD=0.08

# Contact form — Resend delivers email; without RESEND_API_KEY, messages save to .data/contact-inbox.json
CONTACT_TO_EMAIL=hello@enginelabs.com.au
RESEND_API_KEY=
RESEND_FROM_EMAIL=Engine Labs <hello@enginelabs.com.au>
# Optional: used when primary from fails (domain pending). Dev auto-retries onboarding@resend.dev.
# RESEND_FALLBACK_FROM=Engine Labs <onboarding@resend.dev>
